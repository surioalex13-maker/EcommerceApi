# Git Attributes
# Ensure consistent line endings across platforms

# Auto detect text files and normalize line endings to LF
* text=auto

# Java files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Batch scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.tgz binary
